orippAtlas.png 175w,\n/static/e8876440e39808037328dc792504d303/cdf89/HyporippAtlas.png 350w,\n/static/e8876440e39808037328dc792504d303/6ca86/HyporippAtlas.png 700w,\n/static/e8876440e39808037328dc792504d303/26888/HyporippAtlas.png 1400w","sizes":"(min-width: 700px) 700px, 100vw"},"sources":[{"srcSet":"/static/e8876440e39808037328dc792504d303/2242e/HyporippAtlas.avif 175w,\n/static/e8876440e39808037328dc792504d303/fcef1/HyporippAtlas.avif 350w,\n/static/e8876440e39808037328dc792504d303/4b6f9/HyporippAtlas.avif 700w,\n/static/e8876440e39808037328dc792504d303/74ee6/HyporippAtlas.avif 1400w","type":"image/avif","sizes":"(min-width: 700px) 700px, 100vw"},{"srcSet":"/static/e8876440e39808037328dc792504d303/8519c/HyporippAtlas.webp 175w,\n/static/e8876440e39808037328dc792504d303/7a91a/HyporippAtlas.webp 350w,\n/static/e8876440e39808037328dc792504d303/e7306/HyporippAtlas.webp 700w,\n/static/e8876440e39808037328dc792504d303/1368c/HyporippAtlas.webp 1400w","type":"image/webp","sizes":"(min-width: 700px) 700px, 100vw"}]},"width":700,"height":622}}},"tech":["Natural products discovery (RiPP)","Chemoinformatics","Mass spectrometry analysis","Deep learning","Subgraph isomorphism"],"github":null,"external":"https://www.nature.com/articles/s41467-023-39905-4"},"html":"<p>HypoRiPPAtlas is an Atlas of hypothetical natural products for mass spectrometry database search, bridging the gap between large-scale genome mining and mass spectral datasets. In this study, we identified RiPPs in microbes and plants, paving the way for large-scale explorations of biosynthetic pathways and chemical structures of microbial and plant RiPP classes.</p>"}}]}}}